# Apify Configuration
# Sign up at: https://apify.com
# Get your API token from: Settings > Integrations > API tokens

# Your Apify API token
APIFY_TOKEN=apify_api_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Actor to use for trends
# Options:
#   eunit/x-twitter-trends-scraper - Full featured
#   fastcrawler/x-twitter-trends-scraper-2025 - Updated 2025
#   eunit/x-twitter-trends-ppe - Pay per event (cheapest)
APIFY_TRENDS_ACTOR=eunit/x-twitter-trends-scraper

# Default location for trends
# Format: country or country/city
# Examples: united-states, united-states/new-york, worldwide
APIFY_DEFAULT_LOCATION=united-states

# How long to wait for scrape to complete (ms)
APIFY_TIMEOUT_MS=60000
