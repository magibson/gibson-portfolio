# RapidAPI Configuration
# Sign up at: https://rapidapi.com
# Subscribe to Twitter Trends API: https://rapidapi.com/brkygt88/api/twitter-trends5

# Your RapidAPI key
RAPIDAPI_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# API host (usually auto-configured)
RAPIDAPI_HOST=twitter-trends5.p.rapidapi.com

# Default WOEID (Where On Earth ID) for location
# Common values:
#   1 = Worldwide
#   23424977 = United States
#   2459115 = New York
#   2442047 = Los Angeles
#   2487956 = San Francisco
RAPIDAPI_DEFAULT_WOEID=23424977
