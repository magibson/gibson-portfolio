# xAI Grok API Configuration
# Sign up at: https://console.x.ai
# Get your API key from the console

# Your xAI API key
XAI_API_KEY=xai-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Default model to use
# Options: grok-3-mini, grok-3, grok-4
XAI_MODEL=grok-3-mini

# Enable X Search tool (required for trend analysis)
# Cost: $5 per 1,000 searches
XAI_ENABLE_X_SEARCH=true

# Enable Web Search tool (optional, for context)
# Cost: $5 per 1,000 searches  
XAI_ENABLE_WEB_SEARCH=false
